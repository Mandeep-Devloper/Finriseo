generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Application {
  id              String   @id @default(cuid())
  referenceId     String   @unique
  mobile          String
  fullName        String
  employmentType  String
  monthlyIncome   Float
  employer        String?
  experience      String?
  loanAmount      Float
  loanPurpose     String?
  selectedOfferId Int?
  status          String   @default("submitted")
  source          String   @default("web")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mobile])
  @@index([status])
  @@index([createdAt])
}

model OtpLog {
  id        String   @id @default(cuid())
  mobile    String
  status    String   // sent | verified | expired | failed
  createdAt DateTime @default(now())

  @@index([mobile])
  @@index([createdAt])
}

model OtpSession {
  id        String   @id @default(cuid())
  mobile    String   @unique
  otp       String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

// Serverless-safe rate limiting (replaces in-memory Maps).
// One row per rate-limit key, e.g. "otp:9999999999" or "ip:1.2.3.4:submit".
model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([windowStart])
}

// DB-driven loan offers (replaces hardcoded Partner A/B/C).
model Lender {
  id            Int      @id @default(autoincrement())
  name          String
  interestRate  Float    // annual % p.a.
  tenureMonths  Int
  processingFee String   // display string, e.g. "1.5%"
  color         String   // accent color for the offer card
  minIncome     Float    @default(0)     // minimum monthly income to qualify
  maxMultiplier Float    @default(10)    // max loan = monthlyIncome * maxMultiplier
  active        Boolean  @default(true)
  priority      Int      @default(0)     // higher shows first
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active])
}
